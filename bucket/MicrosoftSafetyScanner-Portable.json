            "hash": "cb246084fc6a0cf63b235ee983e0c5b87e76640857460b193a893d9e65d89916"
        },
        "32bit": {
            "url": "https://definitionupdates.microsoft.com/packages/content/msert.exe?packageType=Scanner&packageVersion=1.447.110.0&arch=x86",
