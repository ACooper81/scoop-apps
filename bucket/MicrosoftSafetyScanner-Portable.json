            "hash": "569a35e59f92a89d5ad8a813bc7ccfd83ff55a44c5ff5929d9b6768d7bab3e16"
        },
        "32bit": {
            "url": "https://definitionupdates.microsoft.com/packages/content/msert.exe?packageType=Scanner&packageVersion=1.447.24.0&arch=x86",
