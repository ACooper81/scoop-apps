            "hash": "be5038a0368e16e821b706d8bea75352faf829ce2e760559b87af0ee7f0f5999"
        },
        "32bit": {
            "url": "https://definitionupdates.microsoft.com/packages/content/msert.exe?packageType=Scanner&packageVersion=1.449.669.0&arch=x86",
