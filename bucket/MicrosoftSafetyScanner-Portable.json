            "hash": "6bb2dbf4d7f0274df2b458dfe72c130d71a62e0a22c75c8216fa017721d3e370"
        },
        "32bit": {
            "url": "https://definitionupdates.microsoft.com/packages/content/msert.exe?packageType=Scanner&packageVersion=1.455.70.0&arch=x86",
