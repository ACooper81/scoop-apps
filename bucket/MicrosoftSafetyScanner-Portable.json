            "hash": "b1267bdcd3ee31d81f233448816e38971ce85eecf8c65ced9799e47822d5a396"
        },
        "32bit": {
            "url": "https://definitionupdates.microsoft.com/packages/content/msert.exe?packageType=Scanner&packageVersion=1.447.157.0&arch=x86",
