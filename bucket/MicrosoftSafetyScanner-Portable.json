            "hash": "b7a0f876d95a860ee1f3ae030b1b186f62666916b56996e4e3c5571b6f1d995a"
        },
        "32bit": {
            "url": "https://definitionupdates.microsoft.com/packages/content/msert.exe?packageType=Scanner&packageVersion=1.451.55.0&arch=x86",
